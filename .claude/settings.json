{
  "enableAllProjectMcpServers": true,
  "permissions": {
    "allow": [
      "Bash(flutter test:*)",
      "Bash(flutter analyze:*)",
      "Bash(flutter build:*)",
      "Bash(flutter run:*)",
      "Bash(adb:*)"
    ],
    "ask": [],
    "deny": [
      "Bash(rm -rf:*)",
      "Read(**/.env)",
      "Read(**/secrets/**)"
    ]
  }
}